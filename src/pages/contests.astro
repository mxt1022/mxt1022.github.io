---
import { getCollection } from 'astro:content';
import CompetitionProgress from '../components/CompetitionProgress.astro';
import Layout from '../layouts/Layout.astro';
import { formatDate, withBase } from '../utils/site';

const experiences = (await getCollection('experiences', ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const trackedExperiences = experiences.filter((entry) => entry.data.progress);
const contestsUrl = withBase('/assets/data/contests.json');
const codeforcesUrl = withBase('/assets/data/codeforces.json');
---

<Layout title="竞赛经历" description="算法竞赛与 AI 竞赛的实践记录、方法总结和赛后复盘。">
  <header class="page-hero shell">
    <span class="eyebrow">CONTEST LOG / KEEP ITERATING</span>
    <h1>竞赛经历</h1>
    <p>排名只是快照，真正值得留下的是问题拆解、实验设计、失败路径，以及下一次可以复用的方法。</p>
  </header>

  <section class="section" id="codeforces-record">
    <div class="shell">
      <div class="section-heading">
        <div><span class="eyebrow">01 / CODEFORCES LOG</span><h2>刷题成长记录</h2></div>
        <p>账号 <strong>InsaneArrogant</strong> 的公开训练数据。AC 题目按题目去重，数据每天自动同步两次。</p>
      </div>
      <div id="codeforces-board" class="cf-board" data-source={codeforcesUrl} aria-live="polite">
        <div class="cf-loading mono">正在整理 Codeforces 刷题记录…</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-heading">
        <div><span class="eyebrow">02 / ITERATION LOG</span><h2>竞赛提交时间轴</h2></div>
        <p>按时间记录每次提交、改进策略与分数变化；指标、目标方向、精度和强调色都可以为每场比赛单独设置。</p>
      </div>
      <div class="progress-list">
        {trackedExperiences.map((entry) => entry.data.progress && (
          <CompetitionProgress
            title={entry.data.title}
            platform={entry.data.platform}
            progress={entry.data.progress}
            href={withBase(`/contests/${entry.id}/`)}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-heading">
        <div><span class="eyebrow">03 / RETROSPECTIVES</span><h2>参赛与实践记录</h2></div>
        <p>包括 Kaggle 图像分类、Titanic 特征工程、天池 Baseline 理解与算法训练。</p>
      </div>
      <div class="timeline">
        {experiences.map((entry) => (
          <article class="timeline-item">
            <div class="timeline-meta"><div>{formatDate(entry.data.date)}</div><div>{entry.data.type}</div><div>{entry.data.platform}</div></div>
            <div>
              <span class="eyebrow">{entry.data.status}</span>
              <h2><a href={withBase(`/contests/${entry.id}/`)}>{entry.data.title}</a></h2>
              <p>{entry.data.description}</p>
              <div class="tag-list">{entry.data.tags.map((tag: string) => <span class="tag">#{tag}</span>)}</div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-heading">
        <div><span class="eyebrow">04 / UPCOMING</span><h2>近期 Codeforces</h2></div>
        <p>数据由 GitHub Actions 定时更新，时间会按你的本地时区显示。</p>
      </div>
      <div id="contest-board" class="contest-board" data-source={contestsUrl} aria-live="polite"><p class="mono">正在读取赛程…</p></div>
    </div>
  </section>
  <script>
    const board = document.querySelector<HTMLElement>('#contest-board');
    const codeforcesBoard = document.querySelector<HTMLElement>('#codeforces-board');
    const escapeHtml = (value: string) => value.replace(/[&<>'"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[char] || char);
    const safeNumber = (value: unknown) => Number.isFinite(Number(value)) ? Number(value) : 0;
    const rankClass = (rank: string) => {
      const knownRanks = ['newbie', 'pupil', 'specialist', 'expert', 'candidate master', 'master', 'international master', 'grandmaster', 'international grandmaster', 'legendary grandmaster'];
      return knownRanks.includes(rank) ? rank.replaceAll(' ', '-') : 'unrated';
    };

    type RatingPoint = {
      contest_name: string;
      rank: number;
      old_rating: number;
      new_rating: number;
      delta: number;
      updated_at: string;
      url: string;
    };

    const setupRatingChart = (canvas: HTMLCanvasElement, points: RatingPoint[]) => {
      const context = canvas.getContext('2d');
      const wrap = canvas.closest<HTMLElement>('.cf-chart-wrap');
      const tooltip = wrap?.querySelector<HTMLElement>('.cf-chart-tooltip');
      const detail = wrap?.parentElement?.querySelector<HTMLElement>('.cf-chart-detail');
      if (!context || !wrap || points.length === 0) return;

      let plotted: { x: number; y: number }[] = [];
      let selected = points.length - 1;

      const pointLabel = (point: RatingPoint) => {
        const date = new Date(point.updated_at).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
        const delta = `${point.delta >= 0 ? '+' : ''}${point.delta}`;
        return `${date} · ${point.contest_name} · 排名 ${point.rank} · Rating ${point.new_rating}（${delta}）`;
      };

      const draw = () => {
        const width = Math.max(220, Math.floor(wrap.clientWidth));
        const height = Math.max(260, Math.floor(canvas.getBoundingClientRect().height || 300));
        const ratio = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.floor(width * ratio);
        canvas.height = Math.floor(height * ratio);
        context.setTransform(ratio, 0, 0, ratio, 0, 0);
        context.clearRect(0, 0, width, height);

        const css = getComputedStyle(document.documentElement);
        const accent = css.getPropertyValue('--accent').trim();
        const background = css.getPropertyValue('--surface').trim();
        const muted = css.getPropertyValue('--muted').trim();
        const line = css.getPropertyValue('--line').trim();
        const text = css.getPropertyValue('--text').trim();
        const padding = { top: 24, right: 24, bottom: 38, left: 52 };
        const plotWidth = width - padding.left - padding.right;
        const plotHeight = height - padding.top - padding.bottom;
        const ratings = points.map((point) => point.new_rating);
        const rawMin = Math.min(...ratings);
        const rawMax = Math.max(...ratings);
        const yMin = Math.max(0, Math.floor((rawMin - 100) / 100) * 100);
        const yMax = Math.ceil((rawMax + 100) / 100) * 100;
        const yRange = Math.max(100, yMax - yMin);
        const toX = (index: number) => padding.left + (index / Math.max(1, points.length - 1)) * plotWidth;
        const toY = (rating: number) => padding.top + ((yMax - rating) / yRange) * plotHeight;

        context.font = '11px "DM Mono", monospace';
        context.textBaseline = 'middle';
        context.strokeStyle = line;
        context.fillStyle = muted;
        context.lineWidth = 1;

        for (let index = 0; index <= 4; index += 1) {
          const value = Math.round(yMax - (yRange * index) / 4);
          const y = padding.top + (plotHeight * index) / 4;
          context.beginPath();
          context.moveTo(padding.left, y);
          context.lineTo(width - padding.right, y);
          context.stroke();
          context.textAlign = 'right';
          context.fillText(String(value), padding.left - 10, y);
        }

        const xLabels = [...new Set([0, Math.floor((points.length - 1) / 2), points.length - 1])];
        xLabels.forEach((index) => {
          const date = new Date(points[index].updated_at).toLocaleDateString('zh-CN', { year: '2-digit', month: '2-digit' });
          context.textAlign = index === 0 ? 'left' : index === points.length - 1 ? 'right' : 'center';
          context.fillText(date, toX(index), height - 14);
        });

        plotted = points.map((point, index) => ({ x: toX(index), y: toY(point.new_rating) }));
        const gradient = context.createLinearGradient(0, padding.top, 0, height - padding.bottom);
        gradient.addColorStop(0, accent.startsWith('#') ? `${accent}3d` : accent);
        gradient.addColorStop(1, 'transparent');

        context.beginPath();
        context.moveTo(plotted[0].x, height - padding.bottom);
        plotted.forEach((point) => context.lineTo(point.x, point.y));
        context.lineTo(plotted[plotted.length - 1].x, height - padding.bottom);
        context.closePath();
        context.fillStyle = gradient;
        context.fill();

        context.beginPath();
        plotted.forEach((point, index) => index === 0 ? context.moveTo(point.x, point.y) : context.lineTo(point.x, point.y));
        context.strokeStyle = accent;
        context.lineWidth = 2.5;
        context.lineJoin = 'round';
        context.lineCap = 'round';
        context.stroke();

        plotted.forEach((point, index) => {
          context.beginPath();
          context.arc(point.x, point.y, index === selected ? 5 : 3, 0, Math.PI * 2);
          context.fillStyle = index === selected ? accent : background;
          context.fill();
          context.strokeStyle = accent;
          context.lineWidth = 2;
          context.stroke();
        });

        const current = plotted[selected];
        context.fillStyle = text;
        context.font = '500 11px "DM Mono", monospace';
        context.textAlign = current.x > width - 90 ? 'right' : 'left';
        context.fillText(String(points[selected].new_rating), current.x + (current.x > width - 90 ? -9 : 9), current.y - 13);
        if (detail) detail.textContent = pointLabel(points[selected]);
      };

      const selectFromPointer = (event: PointerEvent) => {
        const bounds = canvas.getBoundingClientRect();
        const x = event.clientX - bounds.left;
        selected = plotted.reduce((closest, point, index) => Math.abs(point.x - x) < Math.abs(plotted[closest].x - x) ? index : closest, 0);
        draw();
        if (!tooltip) return;
        const current = plotted[selected];
        tooltip.innerHTML = `<strong>${escapeHtml(points[selected].contest_name)}</strong><span>Rating ${points[selected].new_rating} · ${points[selected].delta >= 0 ? '+' : ''}${points[selected].delta} · 排名 ${points[selected].rank}</span>`;
        tooltip.hidden = false;
        const tooltipWidth = tooltip.offsetWidth;
        const tooltipHeight = tooltip.offsetHeight;
        tooltip.style.left = `${Math.min(Math.max(6, current.x - tooltipWidth / 2), wrap.clientWidth - tooltipWidth - 6)}px`;
        tooltip.style.top = `${Math.max(6, current.y - tooltipHeight - 14)}px`;
      };

      canvas.addEventListener('pointermove', selectFromPointer);
      canvas.addEventListener('pointerleave', () => {
        selected = points.length - 1;
        if (tooltip) tooltip.hidden = true;
        draw();
      });
      new ResizeObserver(draw).observe(wrap);
      new MutationObserver(draw).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
      draw();
    };

    if (codeforcesBoard) {
      fetch(codeforcesBoard.dataset.source || '')
        .then((response) => response.ok ? response.json() : Promise.reject(new Error('刷题数据读取失败')))
        .then((data) => {
          const profile = data.profile || {};
          const stats = data.stats || {};
          const recent = Array.isArray(data.recent_accepted) ? data.recent_accepted.slice(0, 6) : [];
          const difficulty = Array.isArray(data.difficulty) ? data.difficulty : [];
          const tags = Array.isArray(data.top_tags) ? data.top_tags : [];
          const history: RatingPoint[] = Array.isArray(data.rating_history) ? data.rating_history : [];
          const highestBucket = Math.max(1, ...difficulty.map((item: { count?: number }) => safeNumber(item.count)));
          const updatedAt = data.updated_at ? new Date(data.updated_at).toLocaleString('zh-CN', { dateStyle: 'medium', timeStyle: 'short' }) : '未知';
          const rank = typeof profile.rank === 'string' ? profile.rank : 'unrated';

          const recentHtml = recent.length ? recent.map((problem: { name?: string; index?: string; rating?: number; tags?: string[]; submitted_at?: string; url?: string }) => {
            const date = problem.submitted_at ? new Date(problem.submitted_at).toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' }) : '—';
            const rating = safeNumber(problem.rating);
            return `<li class="cf-solve-row"><a href="${encodeURI(problem.url || profile.profile_url || '#')}" target="_blank" rel="noreferrer"><span class="cf-problem-index">${escapeHtml(problem.index || '?')}</span><span><strong>${escapeHtml(problem.name || 'Untitled problem')}</strong><small>${date} · ${(problem.tags || []).slice(0, 2).map(escapeHtml).join(' / ') || '未分类'}</small></span><span class="cf-problem-rating">${rating || '—'}</span></a></li>`;
          }).join('') : '<li class="cf-empty">还没有可展示的 AC 记录。</li>';

          const difficultyHtml = difficulty.map((item: { label?: string; count?: number }) => {
            const count = safeNumber(item.count);
            const width = Math.round((count / highestBucket) * 100);
            return `<div class="cf-bar-row"><span>${escapeHtml(item.label || '—')}</span><div class="cf-bar-track"><i style="width:${width}%"></i></div><strong>${count}</strong></div>`;
          }).join('');

          const tagsHtml = tags.map((tag: { name?: string; count?: number }) => `<span class="cf-tag">${escapeHtml(tag.name || 'other')} <b>${safeNumber(tag.count)}</b></span>`).join('');
          const ratingRows = [...history].reverse().map((point) => {
            const date = new Date(point.updated_at).toLocaleDateString('zh-CN');
            return `<tr><td>${date}</td><td><a href="${encodeURI(point.url)}" target="_blank" rel="noreferrer">${escapeHtml(point.contest_name)}</a></td><td>${point.rank}</td><td>${point.new_rating}</td><td class="${point.delta >= 0 ? 'positive' : 'negative'}">${point.delta >= 0 ? '+' : ''}${point.delta}</td></tr>`;
          }).join('');
          const ratingChartHtml = history.length ? `<article class="cf-panel cf-rating-panel"><div class="cf-panel-heading"><div><span class="eyebrow">RATING HISTORY</span><h3>比赛 Rating 走势</h3></div><span class="cf-chart-range mono">${new Date(history[0].updated_at).getFullYear()} — ${new Date(history[history.length - 1].updated_at).getFullYear()}</span></div><div class="cf-chart-wrap"><canvas class="cf-rating-chart" role="img" aria-label="${escapeHtml(profile.handle || 'InsaneArrogant')} 共 ${history.length} 场 Rated 比赛的 Rating 折线图"></canvas><div class="cf-chart-tooltip" hidden></div></div><p class="cf-chart-detail mono" aria-live="polite"></p><details class="cf-history-details"><summary>查看逐场 Rating 数据</summary><div class="cf-history-table"><table><thead><tr><th>日期</th><th>比赛</th><th>排名</th><th>Rating</th><th>变化</th></tr></thead><tbody>${ratingRows}</tbody></table></div></details></article>` : '';

          codeforcesBoard.innerHTML = `
            <div class="cf-overview">
              <article class="cf-profile-card">
                <span class="eyebrow">PUBLIC PROFILE</span>
                <a class="cf-handle" href="${encodeURI(profile.profile_url || 'https://codeforces.com/profile/InsaneArrogant')}" target="_blank" rel="noreferrer">${escapeHtml(profile.handle || 'InsaneArrogant')} <span>↗</span></a>
                <div class="cf-rank-line"><span class="cf-rank ${rankClass(rank)}">${escapeHtml(rank)}</span><span>Rating ${safeNumber(profile.rating) || '—'} · Max ${safeNumber(profile.max_rating) || '—'}</span></div>
                ${profile.organization ? `<p class="cf-organization">${escapeHtml(profile.organization)}</p>` : ''}
                <dl class="cf-stats">
                  <div><dt>${safeNumber(stats.solved_count)}</dt><dd>已通过题目</dd></div>
                  <div><dt>${safeNumber(stats.accepted_submissions)}</dt><dd>AC 提交</dd></div>
                  <div><dt>${safeNumber(stats.rated_contests)}</dt><dd>Rated 场次</dd></div>
                  <div><dt>${safeNumber(stats.active_days)}</dt><dd>活跃天数</dd></div>
                </dl>
                <p class="cf-updated mono">Last sync · ${updatedAt}</p>
              </article>
              <article class="cf-panel">
                <div class="cf-panel-heading"><span class="eyebrow">RECENT ACCEPTED</span><a href="${encodeURI(profile.profile_url || '#')}" target="_blank" rel="noreferrer">查看主页 ↗</a></div>
                <ol class="cf-solve-list">${recentHtml}</ol>
              </article>
            </div>
            <div class="cf-analysis">
              ${ratingChartHtml}
              <article class="cf-panel"><span class="eyebrow">DIFFICULTY</span><h3>已通过题目难度</h3><div class="cf-bars">${difficultyHtml}</div></article>
              <article class="cf-panel"><span class="eyebrow">TOP TAGS</span><h3>常练知识点</h3><div class="cf-tags">${tagsHtml}</div><p class="cf-note">统计基于去重后的 AC 题目；无 Rating 的题目不会进入难度分布。</p></article>
            </div>`;
          const chart = codeforcesBoard.querySelector<HTMLCanvasElement>('.cf-rating-chart');
          if (chart && history.length) setupRatingChart(chart, history);
        })
        .catch(() => { codeforcesBoard.innerHTML = '<p class="empty-state">Codeforces 刷题记录暂时无法读取，请稍后重试。</p>'; });
    }

    if (board) {
      fetch(board.dataset.source || '')
        .then((response) => response.ok ? response.json() : Promise.reject(new Error('赛程读取失败')))
        .then((items) => items.filter((item: { start_time: string }) => new Date(item.start_time).getTime() > Date.now()).slice(0, 8))
        .then((items) => {
          if (!items.length) { board.innerHTML = '<p class="empty-state">暂时没有已公布的近期比赛，稍后再来看看。</p>'; return; }
          board.innerHTML = items.map((item: { name: string; url: string; platform: string; start_time: string; duration: string }) => {
            const start = new Date(item.start_time);
            return `<article class="contest-row"><div><h3><a href="${encodeURI(item.url)}" target="_blank" rel="noreferrer">${escapeHtml(item.name)} ↗</a></h3><p>${escapeHtml(item.platform)} · ${escapeHtml(item.duration)}</p></div><div class="contest-time">${start.toLocaleDateString('zh-CN')}<br>${start.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}</div></article>`;
          }).join('');
        })
        .catch(() => { board.innerHTML = '<p class="empty-state">赛程暂时无法读取，请稍后重试。</p>'; });
    }
  </script>
</Layout>
