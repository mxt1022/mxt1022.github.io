---
import { getCollection } from 'astro:content';
import logo from '../assets/avatar.png';
import Layout from '../layouts/Layout.astro';
import { formatDate, withBase } from '../utils/site';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const experiences = (await getCollection('experiences', ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const outputs = [...notes, ...experiences].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 6);
const tagCount = new Set([...notes, ...experiences].flatMap((entry) => entry.data.tags)).size;

const focusAreas = [
  { index: '01', title: 'Algorithms', description: '数据结构、问题建模、复杂度分析，以及 Codeforces 赛后补题与题型归纳。' },
  { index: '02', title: 'AI Competition', description: '机器学习与深度学习实验、特征工程、验证设计和竞赛提交策略。' },
  { index: '03', title: 'CS Project', description: '当前主流的工具、前沿信息、项目信息。例如当下最火的Agent开发' },
];

const experiencesOverview = [
  { marker: 'ONGOING', title: 'Codeforces 训练', meta: 'InsaneArrogant', description: '持续参加比赛、补题并记录 Rating 变化，把做题数量转化为可复用的问题识别能力。' },
  { marker: 'PRACTICE', title: 'AI 竞赛与实验', meta: 'Kaggle · 天池 · Datawhale', description: '围绕表格、图像分类和真实赛题建立 Baseline，记录每次提交、分数和策略调整。' },
  { marker: 'OUTPUT', title: '技术博客与开源代码', meta: 'Astro · GitHub Pages', description: '维护学习笔记、竞赛复盘与算法代码，让输入过程能够被检索、验证和继续改进。' },
];
---

<Layout title="个人主页" description="mxt1022 的个人主页：计算机科学学习、算法训练、AI 竞赛与技术输出。">
  <div class="personal-home">
    <section class="personal-hero">
      <aside class="personal-sidebar" aria-label="个人主页目录">
        <div class="personal-avatar-wrap">
          <img class="personal-avatar" src={logo.src} alt="mxt1022 的终端与上升曲线标志" width="180" height="180" />
          <span class="personal-online"><i></i> RP++ RP->+∞，Learning never stop！</span>
        </div>
        <nav class="personal-menu" aria-label="页面内导航">
          <a href="#intro"><span>01</span> INTRO</a>
          <a href="#focus"><span>02</span> FOCUS</a>
          <a href="#outputs"><span>03</span> OUTPUT</a>
          <a href="#experience"><span>04</span> EXPERIENCE</a>
          <a href="#contact"><span>05</span> CONTACT</a>
        </nav>
      </aside>

      <div class="personal-intro" id="intro">
        <span class="eyebrow">PERSONAL HOMEPAGE / MXT1022</span>
        <h1>你好，我是<br /><span>mxt1022</span></h1>
        <p class="personal-role">CS Learner · Algorithms · Artificial Intelligence</p>
        <p class="personal-lead">初入职场的一名点点点工程师，主要关注于程序设计、机器学习方面竞赛，以及其他前沿工具、项目。这里汇总我的学习方向、近期输出与持续推进的实践。</p>
        <div class="personal-actions">
          <a class="button primary" href="https://github.com/mxt1022" target="_blank" rel="noreferrer">GitHub ↗</a>
          <a class="button" href={withBase('/contests/')}>竞赛记录</a>
          <a class="button" href="mailto:mxt1022@outlook.com">Email</a>
        </div>
        <dl class="personal-stats" aria-label="个人主页内容统计">
          <div><dt>{String(notes.length).padStart(2, '0')}</dt><dd>学习记录</dd></div>
          <div><dt>{String(experiences.length).padStart(2, '0')}</dt><dd>竞赛复盘</dd></div>
          <div><dt>{String(tagCount).padStart(2, '0')}</dt><dd>知识标签</dd></div>
        </dl>
      </div>
    </section>

    <section class="personal-section" id="focus">
      <header><span class="eyebrow">02 / FOCUS</span><h2>关注方向</h2></header>
      <div class="personal-focus-grid">
        {focusAreas.map((area) => (
          <article class="personal-focus-card">
            <span>{area.index}</span>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="personal-section" id="outputs">
      <header><span class="eyebrow">03 / SELECTED OUTPUT</span><h2>近期输出</h2><p>从笔记到竞赛复盘，保留能够继续修正与复用的过程。</p></header>
      <div class="personal-output-list">
        {outputs.map((entry, index) => {
          const isNote = 'category' in entry.data;
          const outputLabel = 'category' in entry.data ? entry.data.category : entry.data.type;
          return (
            <article class="personal-output">
              <span class="personal-output-index">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <span class="eyebrow">{outputLabel}</span>
                <h3><a href={withBase(isNote ? `/notes/${entry.id}/` : `/contests/${entry.id}/`)}>{entry.data.title}</a></h3>
                <p>{entry.data.description}</p>
              </div>
              <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
            </article>
          );
        })}
      </div>
    </section>

    <section class="personal-section" id="experience">
      <header><span class="eyebrow">04 / EXPERIENCE</span><h2>经历与实践</h2></header>
      <div class="personal-experience-list">
        {experiencesOverview.map((item) => (
          <article class="personal-experience">
            <div class="personal-experience-marker"><i></i><span>{item.marker}</span></div>
            <div>
              <h3>{item.title}</h3>
              <span class="personal-experience-meta">{item.meta}</span>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="personal-contact" id="contact">
      <span class="eyebrow">05 / CONTACT</span>
      <h2>一起交流算法、AI 与学习方法</h2>
      <p>欢迎通过 GitHub 或邮件联系</p>
      <div class="personal-actions">
        <a class="button primary" href="mailto:mxt1022@outlook.com">mxt1022@outlook.com</a>
        <a class="button" href={withBase('/about/')}>查看详细介绍</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .personal-home { width: min(1120px, calc(100% - 40px)); margin-inline: auto; }
  .personal-hero { display: grid; grid-template-columns: 240px minmax(0, 1fr); gap: clamp(52px, 9vw, 112px); min-height: calc(100vh - 73px); padding: clamp(70px, 10vw, 120px) 0; align-items: center; }
  .personal-sidebar { align-self: start; }
  .personal-avatar-wrap { position: relative; width: 184px; }
  .personal-avatar { display: block; width: 184px; height: 184px; border: 1px solid color-mix(in srgb, var(--accent) 42%, var(--line)); border-radius: 28px; background: #0b0d0e; object-fit: cover; box-shadow: 0 24px 70px rgb(0 0 0 / .3); transform: rotate(-1.5deg); }
  .personal-online { display: flex; align-items: center; gap: 8px; width: max-content; margin-top: 17px; color: var(--muted); font: 500 .63rem 'DM Mono', monospace; letter-spacing: .08em; }
  .personal-online i { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 5px color-mix(in srgb, var(--accent) 13%, transparent); }
  .personal-menu { display: grid; gap: 2px; margin-top: 38px; }
  .personal-menu a { display: grid; grid-template-columns: 28px 1fr; gap: 10px; padding: 7px 0; color: var(--muted); text-decoration: none; font: .67rem 'DM Mono', monospace; letter-spacing: .08em; }
  .personal-menu a span { color: color-mix(in srgb, var(--muted) 48%, transparent); }
  .personal-menu a:hover { color: var(--accent); }
  .personal-intro { max-width: 760px; scroll-margin-top: 100px; }
  .personal-intro h1 { margin: 16px 0 18px; font-size: clamp(3.6rem, 8vw, 7rem); line-height: .93; letter-spacing: -.075em; }
  .personal-intro h1 span { color: var(--accent); font: 400 .72em/1.25 'Homemade Apple', 'Segoe Print', cursive; letter-spacing: -.065em; }
  .personal-role { margin: 0; color: var(--text); font: 500 .78rem 'DM Mono', monospace; letter-spacing: .08em; text-transform: uppercase; }
  .personal-lead { max-width: 700px; margin: 26px 0 0; color: var(--muted); font-size: clamp(1rem, 1.5vw, 1.18rem); }
  .personal-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 30px; }
  .personal-stats { display: grid; grid-template-columns: repeat(3, 1fr); max-width: 640px; margin: 46px 0 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .personal-stats div { padding: 20px 20px 20px 0; }
  .personal-stats dt { color: var(--text); font: 500 1.6rem 'DM Mono', monospace; }
  .personal-stats dd { margin: 4px 0 0; color: var(--muted); font-size: .74rem; }
  .personal-section { display: grid; grid-template-columns: 210px minmax(0, 1fr); gap: clamp(40px, 8vw, 96px); padding: 96px 0; border-top: 1px solid var(--line); scroll-margin-top: 72px; }
  .personal-section > header h2 { margin: 9px 0 0; font-size: 1.5rem; }
  .personal-section > header p { margin: 16px 0 0; color: var(--muted); font-size: .82rem; }
  .personal-focus-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
  .personal-focus-card { min-height: 245px; padding: 24px; border: 1px solid var(--line); border-radius: 13px; background: var(--surface); }
  .personal-focus-card > span { color: var(--accent); font: .7rem 'DM Mono', monospace; }
  .personal-focus-card h3 { margin: 72px 0 10px; font-size: 1.02rem; }
  .personal-focus-card p { margin: 0; color: var(--muted); font-size: .82rem; }
  .personal-output-list { border-top: 1px solid var(--line); }
  .personal-output { display: grid; grid-template-columns: 38px minmax(0, 1fr) auto; gap: 20px; padding: 27px 0; border-bottom: 1px solid var(--line); }
  .personal-output-index { padding-top: 4px; color: var(--muted); font: .68rem 'DM Mono', monospace; }
  .personal-output h3 { margin: 5px 0 8px; font-size: 1.12rem; line-height: 1.35; }
  .personal-output h3 a { text-decoration: none; }
  .personal-output h3 a:hover { color: var(--accent); }
  .personal-output p { margin: 0; color: var(--muted); font-size: .82rem; }
  .personal-output time { color: var(--muted); font-size: .68rem; white-space: nowrap; }
  .personal-experience-list { position: relative; }
  .personal-experience-list::before { content: ''; position: absolute; top: 10px; bottom: 10px; left: 7px; width: 1px; background: var(--line); }
  .personal-experience { display: grid; grid-template-columns: 105px minmax(0, 1fr); gap: 22px; padding: 0 0 38px; }
  .personal-experience:last-child { padding-bottom: 0; }
  .personal-experience-marker { position: relative; display: flex; align-items: center; gap: 13px; padding-top: 5px; }
  .personal-experience-marker i { position: relative; z-index: 1; width: 15px; height: 15px; border: 4px solid var(--bg); border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 1px var(--accent); }
  .personal-experience-marker span, .personal-experience-meta { color: var(--muted); font: .64rem 'DM Mono', monospace; letter-spacing: .06em; }
  .personal-experience h3 { margin: 0 0 3px; font-size: 1.1rem; }
  .personal-experience p { margin: 11px 0 0; color: var(--muted); font-size: .85rem; }
  .personal-contact { margin: 0 0 96px; padding: clamp(34px, 6vw, 64px); border: 1px solid var(--line); border-radius: 18px; background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 13%, var(--surface)), var(--surface) 64%); scroll-margin-top: 96px; }
  .personal-contact h2 { max-width: 760px; margin: 14px 0 16px; font-size: clamp(2rem, 5vw, 4rem); line-height: 1.04; letter-spacing: -.055em; }
  .personal-contact p { max-width: 650px; margin: 0; color: var(--muted); }
  @keyframes personal-title-in { from { opacity: 0; transform: translateY(24px); filter: blur(6px); } to { opacity: 1; transform: none; filter: none; } }
  .personal-intro h1 { animation: personal-title-in .8s cubic-bezier(.16, 1, .3, 1) .08s both; }
  @supports (animation-timeline: view()) {
    .personal-section, .personal-contact { animation: personal-section-in both; animation-timeline: view(); animation-range: entry 5% cover 24%; }
    @keyframes personal-section-in { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: none; } }
  }
  @media (max-width: 900px) {
    .personal-hero { grid-template-columns: 190px minmax(0, 1fr); gap: 42px; }
    .personal-avatar-wrap, .personal-avatar { width: 160px; }
    .personal-avatar { height: 160px; }
    .personal-section { grid-template-columns: 1fr; gap: 34px; }
    .personal-focus-grid { grid-template-columns: 1fr; }
    .personal-focus-card { min-height: 180px; }
    .personal-focus-card h3 { margin-top: 40px; }
  }
  @media (max-width: 650px) {
    .personal-home { width: min(100% - 28px, 1120px); }
    .personal-hero { grid-template-columns: 1fr; min-height: auto; padding: 64px 0 82px; }
    .personal-sidebar { display: grid; grid-template-columns: auto 1fr; gap: 26px; align-items: center; }
    .personal-avatar-wrap, .personal-avatar { width: 112px; }
    .personal-avatar { height: 112px; border-radius: 20px; }
    .personal-online { font-size: .55rem; }
    .personal-menu { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 14px; margin-top: 0; }
    .personal-intro h1 { font-size: clamp(3.3rem, 16vw, 5rem); }
    .personal-stats { margin-top: 36px; }
    .personal-stats div { padding-right: 10px; }
    .personal-output { grid-template-columns: 28px minmax(0, 1fr); gap: 12px; }
    .personal-output time { grid-column: 2; }
    .personal-experience { grid-template-columns: 1fr; gap: 9px; padding-left: 28px; }
    .personal-experience-list::before { left: 7px; }
    .personal-experience-marker { margin-left: -28px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .personal-intro h1, .personal-section, .personal-contact { opacity: 1; transform: none; filter: none; animation: none; }
  }
</style>
