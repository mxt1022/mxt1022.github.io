---
import Layout from '../layouts/Layout.astro';

const techStack = [
  { name: 'C++', category: '语言', slug: 'cplusplus', color: '00599C' },
  { name: 'Python', category: '语言', slug: 'python', color: '3776AB' },
  { name: 'Java', category: '语言', slug: 'openjdk', color: 'ED8B00' },
  { name: 'TypeScript', category: '语言', slug: 'typescript', color: '3178C6' },
  { name: 'PyTorch', category: 'AI / ML', slug: 'pytorch', color: 'EE4C2C' },
  { name: 'TensorFlow', category: 'AI / ML', slug: 'tensorflow', color: 'FF6F00' },
  { name: 'scikit-learn', category: 'AI / ML', slug: 'scikitlearn', color: 'F7931E' },
  { name: 'Astro', category: 'Web', slug: 'astro', color: 'BC52EE' },
  { name: 'Git', category: '工具', slug: 'git', color: 'F05032' },
  { name: 'Linux', category: '工具', slug: 'linux', color: 'FCC624' },
];

const resumeFacts = [
  { label: '个人定位', value: 'CS Learner' },
  { label: '主要方向', value: 'Algorithms / AI' },
  { label: '竞赛账号', value: 'InsaneArrogant' },
  { label: '持续输出', value: 'Notes / Reviews / Code' },
];

const resumeItems = [
  {
    marker: 'FOCUS',
    title: '计算机科学学习',
    description: '围绕算法与数据结构、机器学习、深度学习及系统基础建立长期学习主线，并通过课程与项目补齐知识结构。',
  },
  {
    marker: 'PRACTICE',
    title: '算法与 AI 竞赛实践',
    description: '持续进行 Codeforces 训练与赛后补题，同时参与 Kaggle、天池及 Datawhale 相关实践，记录每次实验、提交和策略变化。',
  },
  {
    marker: 'OUTPUT',
    title: '技术写作与开源记录',
    description: '使用 Astro 维护个人技术博客，在 GitHub 整理算法代码，把课程笔记、错误路径和竞赛复盘转化为可检索的公开资料。',
  },
  {
    marker: 'NOW',
    title: '当前目标',
    description: '提升算法问题识别能力与 AI 实验的可复现性，用稳定的小步迭代积累可以长期复用的方法和工程经验。',
  },
];
---

<Layout title="关于" description="关于 mxt 与这个持续更新的学习博客。">
  <header class="page-hero shell">
    <span class="eyebrow">ABOUT / NOW & NEXT</span>
    <h1>关于我与<br />这份长期记录</h1>
  </header>
  <section class="section">
    <div class="shell profile-grid">
      <aside class="profile-card">
        <div class="profile-avatar" aria-hidden="true">m</div>
        <span class="eyebrow">CS LEARNER</span>
        <h2>mxt</h2>
        <p>计算机科学与技术方向，关注算法、人工智能与系统基础。</p>
        <div class="footer-links"><a href="https://github.com/mxt1022" target="_blank" rel="noreferrer">GitHub ↗</a><a href="mailto:mxt1022@outlook.com">Email ↗</a></div>
      </aside>
      <div class="about-copy">
        <section>
          <span class="eyebrow">WHY THIS BLOG</span>
          <h2>记录不是终点，而是一次重新理解。</h2>
          <p>这个博客从早期的课程 Wiki 演进而来。学习内容越多，越需要一个结构清晰的地方保存思路、代码和复盘。这里不包装“标准答案”，更愿意留下推导过程以及曾经踩过的坑。</p>
        </section>
        <section class="resume-section">
          <span class="eyebrow">PROFILE / RESUME</span>
          <h2>你好，我是 mxt。</h2>
          <p class="resume-lead">一名以项目与竞赛驱动学习的计算机科学学习者。我关注算法、人工智能与系统基础，也在持续练习如何把一个模糊的问题拆成可验证、可复现的步骤。</p>
          <dl class="resume-facts" aria-label="个人简历摘要">
            {resumeFacts.map((fact) => (
              <div>
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </dl>
          <div class="resume-list" aria-label="个人经历与方向">
            {resumeItems.map((item) => (
              <article class="resume-entry">
                <span class="resume-marker">{item.marker}</span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </article>
            ))}
          </div>
          <div class="resume-actions">
            <a class="button primary" href="https://github.com/mxt1022" target="_blank" rel="noreferrer">查看 GitHub ↗</a>
            <a class="button" href="mailto:mxt1022@outlook.com">邮件联系</a>
          </div>
        </section>
        <section>
          <span class="eyebrow">TOOLBOX</span>
          <h2>技术栈</h2>
          <p>在算法训练、AI 实验和博客工程中持续使用与学习的语言、框架及工具。</p>
          <div class="tech-stack" aria-label="技术栈列表">
            {techStack.map((tech) => (
              <article class="tech-item" style={`--tech-color: #${tech.color}`}>
                <div class="tech-icon">
                  <img
                    src={`https://cdn.jsdelivr.net/npm/simple-icons@16.26.0/icons/${tech.slug}.svg`}
                    alt=""
                    width="28"
                    height="28"
                    loading="lazy"
                  />
                </div>
                <div>
                  <strong>{tech.name}</strong>
                  <span>{tech.category}</span>
                </div>
              </article>
            ))}
          </div>
        </section>
        <section>
          <span class="eyebrow">CURRENT ROADMAP</span>
          <h2>当前学习路线</h2>
          <div class="roadmap">
            <div><strong>算法</strong><br /><span>数据结构、LeetCode / Codeforces 训练与题型归纳</span></div>
            <div><strong>人工智能</strong><br /><span>机器学习、深度学习、Kaggle / 天池竞赛实践</span></div>
            <div><strong>计算机基础</strong><br /><span>CS61 系列、CSAPP、操作系统与网络</span></div>
            <div><strong>工程实践</strong><br /><span>用小项目把知识连接起来，并持续改进工具链</span></div>
          </div>
        </section>
        <section>
          <span class="eyebrow">PRINCIPLE</span>
          <h2>日拱一卒</h2>
          <p>不把路线图当作进度表，也不追求同时完成所有课程。优先把一个问题弄明白、做出来、写下来，再继续向前。</p>
        </section>
      </div>
    </div>
  </section>
</Layout>
