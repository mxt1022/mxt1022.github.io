---
import '../styles/global.css';
import logo from '../assets/logo.png';
import { ClientRouter } from 'astro:transitions';
import { siteMeta, withBase } from '../utils/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = siteMeta.title, description = siteMeta.description, image = withBase('/og.png') } = Astro.props;
const pageTitle = title === siteMeta.title ? title : `${title} · ${siteMeta.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';
const nav = [
  { href: '/', label: '首页' },
  { href: '/profile/', label: '个人主页' },
  { href: '/notes/', label: '学习记录' },
  { href: '/contests/', label: '竞赛经历' },
  { href: '/about/', label: '关于' },
];
const pageTransition = {
  forwards: {
    old: { name: 'page-out-forward', duration: '180ms', easing: 'cubic-bezier(.4, 0, 1, 1)', fillMode: 'both' },
    new: { name: 'page-in-forward', duration: '360ms', easing: 'cubic-bezier(.16, 1, .3, 1)', fillMode: 'both' },
  },
  backwards: {
    old: { name: 'page-out-back', duration: '180ms', easing: 'cubic-bezier(.4, 0, 1, 1)', fillMode: 'both' },
    new: { name: 'page-in-back', duration: '360ms', easing: 'cubic-bezier(.16, 1, .3, 1)', fillMode: 'both' },
  },
};
---

<!doctype html>
<html lang="zh-CN" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0d0e" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={logo.src} />
    <link rel="alternate" type="application/rss+xml" title={siteMeta.title} href={withBase('/rss.xml')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    <title>{pageTitle}</title>
    <ClientRouter fallback="animate" />
    <script is:inline>
      document.documentElement.dataset.theme = localStorage.getItem('theme') || 'dark';
    </script>
  </head>
  <body>
    <a class="skip-link" href="#content">跳到正文</a>
    <header class="site-header">
      <div class="shell nav-wrap">
        <a class="brand" href={withBase('/')} aria-label="mxt.log 首页">
          <span class="brand-mark" aria-hidden="true"><img src={logo.src} alt="" width="30" height="30" /></span>
          <span>mxt<span class="accent">.log</span></span>
        </a>
        <nav aria-label="主导航">
          {nav.map((item) => (
            <a class:list={{ active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }} href={withBase(item.href)}>
              {item.label}
            </a>
          ))}
        </nav>
        <button class="theme-toggle" type="button" aria-label="切换明暗主题" title="切换明暗主题"><span aria-hidden="true">◐</span></button>
      </div>
    </header>

    <main id="content" transition:name="page-content" transition:animate={pageTransition}><slot /></main>

    <footer class="site-footer">
      <div class="shell footer-grid">
        <div>
          <a class="brand" href={withBase('/')}><span class="brand-mark" aria-hidden="true"><img src={logo.src} alt="" width="30" height="30" /></span><span>mxt<span class="accent">.log</span></span></a>
          <p>持续学习，持续复盘，持续输出。</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/mxt1022" target="_blank" rel="noreferrer">GitHub ↗</a>
          <a href="mailto:mxt1022@outlook.com">Email ↗</a>
          <a href={withBase('/rss.xml')}>RSS ↗</a>
        </div>
        <p class="copyright">© {new Date().getFullYear()} mxt · Built with Astro</p>
      </div>
    </footer>

    <script>
      const copyCode = async (text: string) => {
        if (!navigator.clipboard?.writeText) throw new Error('Clipboard API unavailable');
        await navigator.clipboard.writeText(text);
      };

      const setupCodeCopyButtons = () => {
        document.querySelectorAll<HTMLElement>('.prose pre').forEach((pre) => {
          if (pre.closest('.code-block')) return;
          const code = pre.querySelector('code');
          if (!code) return;

          const wrapper = document.createElement('div');
          wrapper.className = 'code-block';
          pre.before(wrapper);
          wrapper.append(pre);

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'code-copy';
          button.textContent = '复制';
          button.setAttribute('aria-label', '复制代码');
          wrapper.append(button);

          button.addEventListener('click', async () => {
            try {
              await copyCode(code.textContent || '');
              button.textContent = '已复制';
              button.classList.add('is-copied');
              button.setAttribute('aria-label', '代码已复制');
            } catch {
              button.textContent = '复制失败';
              button.classList.add('is-error');
              button.setAttribute('aria-label', '代码复制失败');
            }

            window.setTimeout(() => {
              button.textContent = '复制';
              button.classList.remove('is-copied', 'is-error');
              button.setAttribute('aria-label', '复制代码');
            }, 1600);
          });
        });
      };

      const setupThemeToggle = () => {
        const button = document.querySelector<HTMLButtonElement>('.theme-toggle');
        button?.addEventListener('click', () => {
          const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        });
      };

      document.addEventListener('astro:before-swap', (event) => {
        event.newDocument.documentElement.dataset.theme = document.documentElement.dataset.theme || localStorage.getItem('theme') || 'dark';
      });
      document.addEventListener('astro:page-load', setupThemeToggle);
      document.addEventListener('astro:page-load', setupCodeCopyButtons);
    </script>
  </body>
</html>
