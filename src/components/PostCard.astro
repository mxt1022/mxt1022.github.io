---
import { formatDate, withBase } from '../utils/site';

interface Props {
  title: string;
  description: string;
  date: Date;
  href: string;
  label: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, date, href, label, tags = [], featured = false } = Astro.props;
---

<article class:list={['post-card', { featured }]}>
  <div class="post-card__meta">
    <span class="eyebrow">{label}</span>
    <time datetime={date.toISOString()}>{formatDate(date)}</time>
  </div>
  <h3><a href={withBase(href)}>{title}</a></h3>
  <p>{description}</p>
  <div class="post-card__footer">
    <div class="tag-list" aria-label="标签">
      {tags.slice(0, 3).map((tag) => <span class="tag">#{tag}</span>)}
    </div>
    <a class="text-link" href={withBase(href)} aria-label={`阅读：${title}`}>阅读 <span aria-hidden="true">↗</span></a>
  </div>
</article>
